PORT=4000
DATABASE_URL=
UPLOAD_PATH=backend/uploads
CORS_ORIGIN=http://localhost:8080
APP_PARTITION_DEFAULT=nxt-lvl-suites
VITE_API_BASE_URL=
VITE_APP_PARTITION=nxt-lvl-suites
# Suite platform integration - redirect unauthenticated users to Suite login
# Production: https://ntlops.com
# Local dev: http://localhost:3000 (if running Suite locally)
VITE_SUITE_URL=
# Optional: Suite login path if your Suite auth page is not /login
VITE_SUITE_LOGIN_PATH=/site/login
# Optional: Suite signup path if your Suite register page is not /signup
VITE_SUITE_SIGNUP_PATH=/site/register

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Set once to register the first platform admin; leave empty after
PLATFORM_SETUP_TOKEN=
