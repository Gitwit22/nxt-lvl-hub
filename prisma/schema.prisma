model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships Membership[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  firstName    String?
  lastName     String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships  Membership[]
}

